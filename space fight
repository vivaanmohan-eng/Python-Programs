space = pygame.transform.scale(pygame.image.load("Space_Fighting\Assets\\bg.png"),(WIDTH,HEIGHT))

def draw_window(red,yellow,red_bullets,yellow_bullets,red_hp,yellow_hp):
    screen.blit(space,(0,0))
    pygame.draw.rect(screen,BLACK,border)

    red_health_text = hp.render("HEALTH" + str(red_hp),1,WHITE)
    yellow_health_text = hp.render("HEALTH" + str(yellow_hp),1,WHITE)

    screen.blit(red_health_text,(WIDTH-red_health_text.get_width()-10,10))
    screen.blit(yellow_health_text,(10,10))

    for bullet in red_bullets:
        pygame.draw.rect(screen,RED,bullet)

    for bullet in yellow_bullets:
        pygame.draw.rect(screen,YELLOW,bullet)
    pygame.display.update()

